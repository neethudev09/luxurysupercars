# =============================================================================
# Luxury Supercars Dubai — environment variables
# Copy to .env.local and fill in. Mirror the same keys in Vercel (Project →
# Settings → Environment Variables) for Production / Preview / Development.
# =============================================================================

# -----------------------------------------------------------------------------
# Contact form delivery (Resend)  —  REQUIRED for production
# -----------------------------------------------------------------------------
# Without RESEND_API_KEY the form silently console-logs and tells the
# visitor "we received your enquiry". Fine for staging, NOT for prod.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Where enquiries are delivered. Defaults to info@luxurysupercarsdubai.com
# if unset — override here if ops wants a routing alias.
ENQUIRY_TO=info@luxurysupercarsdubai.com

# Verified sender (must be a domain you control + verified in Resend).
# Until your domain is verified you can use the Resend sandbox sender:
#   ENQUIRY_FROM="LSR Enquiries <onboarding@resend.dev>"
ENQUIRY_FROM=LSR Enquiries <enquiries@notifications.luxurysupercarsdubai.com>

# -----------------------------------------------------------------------------
# Sanity CMS  —  OPTIONAL (Studio scaffolded, not yet the source of truth)
# -----------------------------------------------------------------------------
# Studio at /studio will show "not configured" until these are filled.
# The marketing site itself works without them — content currently lives
# in lib/*.ts. Wire these up once the team decides to migrate.
NEXT_PUBLIC_SANITY_PROJECT_ID=pkpvmml9
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-05-01

# Write token (server-only, used by migration scripts). Generate in
# sanity.io → Project → API → Tokens with Editor or Deploy Studio access.
SANITY_API_TOKEN=sk_placeholder_replace_with_your_token

# -----------------------------------------------------------------------------
# Robots / canonical URL  —  OPTIONAL
# -----------------------------------------------------------------------------
# Used by app/robots.ts to detect production vs. staging. On Vercel,
# VERCEL_ENV is auto-injected (production / preview / development) — you
# normally don't need to set NEXT_PUBLIC_SITE_URL there. Set it only for
# self-hosted deployments or non-standard domains.
# NEXT_PUBLIC_SITE_URL=https://luxurysupercarsdubai.com
